# =====================================================================
# Configuracao do Automador de Ads — copie para .env.local e preencha.
# =====================================================================

# --- Anthropic / Claude API (corta a copy em batidas) ---
# Pegue em https://console.anthropic.com/settings/keys
# OBS: usamos CLAUDE_KEY (e nao ANTHROPIC_API_KEY) porque essa ultima e' interceptada
# pelo SDK do Anthropic em alguns ambientes Windows + Next.js dev mode.
CLAUDE_KEY=cole_sua_chave_anthropic_aqui

# --- Pexels API (banco de videos cinematograficos gratis) ---
# 1. Crie conta gratuita: https://www.pexels.com/join/
# 2. Crie chave: https://www.pexels.com/api/new/
# 3. Cole a chave aqui (e o ANTHROPIC_API_KEY acima):
PEXELS_API_KEY=cole_sua_chave_pexels_aqui

# --- Pasta opcional de videos seus (override do Pexels) ---
USER_VIDEO_DIR=./my_videos

# --- Auth (proteção da app por senha única) ---
# Se preenchido, exige senha pra acessar. Se vazio, app fica público (dev).
# Em produção (Railway), DEFINIR uma senha forte aqui.
AUTH_PASSWORD=

# --- Storage path (produção) ---
# Em dev deixa vazio (usa cwd). Em Railway aponta pra volume persistente:
# STORAGE_DIR=/data
STORAGE_DIR=

# --- Remotion: Chromium do sistema (produção) ---
# Em dev deixa vazio (Remotion baixa próprio Chromium).
# Em Docker (Railway) aponta pra Chromium instalado no container:
# REMOTION_BROWSER_EXECUTABLE=/usr/bin/chromium
REMOTION_BROWSER_EXECUTABLE=

# --- URL pública do site (opcional) ---
# Em dev: deixa vazio (usa http://127.0.0.1:3000)
# Em produção: NÃO PRECISA setar — o Remotion roda Chromium internamente
# e usa http://127.0.0.1:$PORT pra fetch local. Só seta se tiver caso especial.
PUBLIC_BASE_URL=
